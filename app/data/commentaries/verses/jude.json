f":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":22}},{"match":"hash","source_href":"../../mhc/jude/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":17},"text_hash":"818e39fb934c4e97a398790316870c3558d6b432"},{"match":"direct","source_href":"../../gill/jude/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":22}}],"23":[{"match":"hash","source_href":"../../mhc/jude/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":17},"text_hash":"818e39fb934c4e97a398790316870c3558d6b432"},{"match":"direct","source_href":"../../gill/jude/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":23}}],"24":[{"match":"direct","source_href":"../../ellicott/jude/1.htm","source_id":"ellicott","source_name":"Ellicott's Commentary for English Readers","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":24}},{"match":"direct","source_href":"../../pulpit/jude/1.htm","source_id":"pulpit","source_name":"Pulpit Commentary","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":24}},{"match":"direct","source_href":"../../mhc/jude/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":24}},{"match":"direct","source_href":"../../gill/jude/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":24}}],"25":[{"match":"hash","source_href":"../../mhc/jude/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":24},"text_hash":"fd009a8730f3201a5d7ebb3ac20aee50e332979a"},{"commentary_html":"To the only wise God our Saviour,.... By whom is meant, not the Trinity of Persons in general, nor the Father in particular; but the Lord Jesus Christ, who is truly God, though not to the exclusion of the Father and Spirit; and is the wisdom of God, and the author of all wisdom, natural and spiritual; and is the only Saviour of his people; and to him may be, as is ascribed, the <p>glory of his deity, and divine sonship, of his mediatorial works, and of salvation: <p>and majesty: which belongs to him as God, and which he has in his human nature, being crowned with glory, and honour, and enthroned and set down at the right hand of God: <p>dominion; both natural, the kingdom of nature and providence belonging to him, and mediatorial, which is above all, reaches far and wide, and will last for ever: <p>and power; in making and upholding all things; in redeeming his people; in protecting and defending them, and in destroying his and their enemies; in raising the dead, and judging the world. Though the Alexandrian copy, and some others, and the Vulgate Latin version, read, \"to the only God our Saviour, by Jesus Christ our Lord\", and leave out the word \"wise\"; and so they are to be understood of God the Father; but the Ethiopic version reads, \"this is the only God our Saviour Jesus Christ, to whom\", &amp;c. And all this is to be attributed to him, <p>both now, and ever; in the present life, and to all eternity, <p>Amen: which is an assent unto it, that so it should be; and a wish that so it may be; and an expression of faith, and strong asseveration, that so it shall be.","content_hash":"a5228a18331ca93b79f0c2c390619ae636cdd15b","links":[],"source_href":"../../gill/jude/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","text_hash":"07006d6b7f0eeba6422dbce8474cc51ecede142d"}],"3":[{"match":"direct","source_href":"../../ellicott/jude/1.htm","source_id":"ellicott","source_name":"Ellicott's Commentary for English Readers","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":3}},{"match":"direct","source_href":"../../pulpit/jude/1.htm","source_id":"pulpit","source_name":"Pulpit Commentary","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":3}},{"match":"hash","source_href":"../../mhc/jude/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":1},"text_hash":"0c5808001c6166116c0bbb18bf04a83216d030fa"},{"match":"direct","source_href":"../../gill/jude/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":3}}],"4":[{"match":"direct","source_href":"../../pulpit/jude/1.htm","source_id":"pulpit","source_name":"Pulpit Commentary","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":4}},{"match":"hash","source_href":"../../mhc/jude/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":1},"text_hash":"0c5808001c6166116c0bbb18bf04a83216d030fa"},{"match":"direct","source_href":"../../gill/jude/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":4}}],"5":[{"match":"direct","source_href":"../../ellicott/jude/1.htm","source_id":"ellicott","source_name":"Ellicott's Commentary for English Readers","source_ref":{"book_id":"jude","chapter":1,"entry_index":0,"source_chapter":1,"verse":5}},{"match":"direct","source_href":"../../pulpit/jude/1.htm","source_id":"