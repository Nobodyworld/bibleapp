the epistle was sent; and therefore the word is in the plural number; and the Syriac version adds pertinently enough, \"my brethren\": the salutation is the same as in all the epistles; the form of it agrees with <a href=\"../../par/galatians/6-18.htm\">Galatians 6:18</a> the subscription of the epistle is, <p>written from Rome, to Philemon, by Onesimus, a servant; that is, it was written by the Apostle Paul when at Rome, and sent to Philemon by the hands of Onesimus, who was his servant, and upon whose account the letter was written.","content_hash":"da75b9d897518a697395fad64ff57ac054ed4277","links":[{"book_id":"galatians","chapter":6,"href":"../../par/galatians/6-18.htm","label":"Galatians 6:18","verse_end":18,"verse_start":18}],"source_href":"../../gill/philemon/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","text_hash":"7104b9f9b8ec64cd10188b7ab46316b79825883e"}],"3":[{"match":"direct","source_href":"../../pulpit/philemon/1.htm","source_id":"pulpit","source_name":"Pulpit Commentary","source_ref":{"book_id":"philemon","chapter":1,"entry_index":0,"source_chapter":1,"verse":3}},{"match":"hash","source_href":"../../mhc/philemon/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"philemon","chapter":1,"entry_index":0,"source_chapter":1,"verse":1},"text_hash":"148f3fd2e719821a0019965bc2f1688ac9597aae"},{"match":"direct","source_href":"../../gill/philemon/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","source_ref":{"book_id":"philemon","chapter":1,"entry_index":0,"source_chapter":1,"verse":3}}],"4":[{"match":"direct","source_href":"../../ellicott/philemon/1.htm","source_id":"ellicott","source_name":"Ellicott's Commentary for English Readers","source_ref":{"book_id":"philemon","chapter":1,"entry_index":0,"source_chapter":1,"verse":4}},{"match":"direct","source_href":"../../pulpit/philemon/1.htm","source_id":"pulpit","source_name":"Pulpit Commentary","source