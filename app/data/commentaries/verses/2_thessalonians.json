_chapter":3,"verse":18}},{"match":"direct","source_href":"../../pulpit/2_thessalonians/3.htm","source_id":"pulpit","source_name":"Pulpit Commentary","source_ref":{"book_id":"2_thessalonians","chapter":3,"entry_index":0,"source_chapter":3,"verse":18}},{"match":"hash","source_href":"../../mhc/2_thessalonians/3.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"2_thessalonians","chapter":3,"entry_index":0,"source_chapter":3,"verse":16},"text_hash":"f425bbbaf3aed63d72fc12d9dca222dc7be266a6"},{"commentary_html":"The grace of our Lord Jesus Christ be with you all. Amen. This was the sign or token; See Gill on <a href=\"../../par/romans/16-20.htm\">Romans 16:20</a> The subscription to this epistle is, \"The Second Epistle to the Thessalonians was written from Athens\"; though it seems rather to be written from Corinth. In the Syriac version it is said, <p>\"the Second Epistle to the Thessalonians, which is written from Laodicea of Pisidia, and sent by the hands of Tychicus.''","content_hash":"5d0650a898b1251e81ae6099e76794ee9efa37bb","links":[{"book_id":"romans","chapter":16,"href":"../../par/romans/16-20.htm","label":"Romans 16:20","verse_end":20,"verse_start":20}],"source_href":"../../gill/2_thessalonians/3.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","text_hash":"4352fd58b605832e3988fc39e13c07d656cbd3aa"}],"2":[{"match":"direct","source_href":"../../ellicott/2_thessalonians/3.htm","source_id":"ellicott","source_name":"Ellicott's Commentary for English Readers","source_ref":{"book_id":"2_thessalonians","chapter":3,"entry_index":0,"source_chapter":3,"verse":2}},{"match":"direct","source_href":"../../pulpit/2_thessalonians/3.htm","source_id":"pulpit","source_name":"Pulpit Commentary","source_ref":{"book_id":"2_thessalonians","chapter":3,"entry_index":0,"source_chapter":3,"verse":2}},{"match":"hash","source_href":"../../mhc/2_thessalonians/3.htm","source_id":"mhc","source_name":"Matthew Henry's