mentary","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":9},"text_hash":"6274347be962e6e51168f3190183261e6ff60723"},{"match":"direct","source_href":"../../gill/3_john/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":11}}],"12":[{"match":"direct","source_href":"../../pulpit/3_john/1.htm","source_id":"pulpit","source_name":"Pulpit Commentary","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":12}},{"match":"hash","source_href":"../../mhc/3_john/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":9},"text_hash":"6274347be962e6e51168f3190183261e6ff60723"},{"match":"direct","source_href":"../../gill/3_john/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":12}}],"13":[{"match":"direct","source_href":"../../ellicott/3_john/1.htm","source_id":"ellicott","source_name":"Ellicott's Commentary for English Readers","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":13}},{"match":"direct","source_href":"../../pulpit/3_john/1.htm","source_id":"pulpit","source_name":"Pulpit Commentary","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":13}},{"match":"direct","source_href":"../../mhc/3_john/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":13}},{"match":"direct","source_href":"../../gill/3_john/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":13}}],"14":[{"match":"hash","source_href":"../../mhc/3_john/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":13},"text_hash":"a358a8d2c6cd2f19f8c1a0dd1cf56008bede3d82"},{"commentary_html":"But I trust I shall shortly see thee,.... Either at Ephesus, where John was, or rather at the place where Gaius lived, see <a href=\"../../par/3_john/1-10.htm\">3 John 1:10</a>; <p>and we shall speak face to face; freely and familiarly converse together about these things, which were not thought proper to be committed to writing: <p>peace be to thee; which was the usual form of salutation with the Jews, and John was one; See Gill on <a href=\"../../par/john/20-19.htm\">John 20:19</a>; <p>our friends salute thee; or send their Christian salutation to thee, wishing all health and prosperity in soul and body; meaning the members of the church at Ephesus: the Arabic version reads, \"thy friends\"; such at Ephesus as had a particular knowledge of him, and affection for him. The Vulgate Latin version reads, \"the friends\": the members in general; and the Alexandrian copy reads, \"the brethren\"; and the Syriac version, our brethren: and then the epistle is closed thus, <p>greet the friends by name; meaning those that were where Gaius lived, to whom the apostle sends his salutation, and desires it might be delivered to each of them, as if they had been mentioned by name. This and the epistle of James are the only epistles which are concluded without the word \"Amen\".","content_hash":"7daf79ee6a03bbcc4628baa9053a65fcc5fe786e","links":[{"book_id":"3_john","chapter":1,"href":"../../par/3_john/1-10.htm","label":"3 John 1:10","verse_end":10,"verse_start":10},{"book_id":"john","chapter":20,"href":"../../par/john/20-19.htm","label":"John 20:19","verse_end":19,"verse_start":19}],"source_href":"../../gill/3_john/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","text_hash":"ba04c6cd44db1d2a5227a9ad62a4552f9d87b3a3"}],"2":[{"match":"direct","source_href":"../../ellicott/3_john/1.htm","source_id":"ellicott","source_name":"Ellicott's Commentary for English Readers","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":2}},{"match":"direct","source_href":"../../pulpit/3_john/1.htm","source_id":"pulpit","source_name":"Pulpit Commentary","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":2}},{"match":"hash","source_href":"../../mhc/3_john/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":1},"text_hash":"5ac2d3ccde12d2216dc7ce994fb15da3ad3fec68"},{"match":"direct","source_href":"../../gill/3_john/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":2}}],"3":[{"match":"direct","source_href":"../../pulpit/3_john/1.htm","source_id":"pulpit","source_name":"Pulpit Commentary","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":3}},{"match":"hash","source_href":"../../mhc/3_john/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":1},"text_hash":"5ac2d3ccde12d2216dc7ce994fb15da3ad3fec68"},{"match":"direct","source_href":"../../gill/3_john/1.htm","source_id":"gill","source_name":"Gill's Exposition of the Entire Bible","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":3}}],"4":[{"match":"hash","source_href":"../../mhc/3_john/1.htm","source_id":"mhc","source_name":"Matthew Henry's Concise Commentary","source_ref":{"book_id":"3_john","chapter":1,"entry_index":0,"source_chapter":1,"verse":1},"text_hash":"5ac2d3ccde12d2216dc7ce994fb15da3ad3fec68"},{"match":"direct","source_hre