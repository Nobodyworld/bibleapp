{"book": {"id": "micah", "name": "Micah", "osis": "Mic"}, "chapters": {"1": {"10": [{"anchor": {"anchor_index": 1, "char_offset": 23, "scope": "verse", "word_index": 6}, "marker": "c", "text": "Gath sounds like the Hebrew for tell ."}, {"anchor": {"anchor_index": 2, "char_offset": 78, "scope": "verse", "word_index": 17}, "marker": "d", "text": "Beth-Leaphrah means house of dust ."}], "11": [{"anchor": {"anchor_index": 1, "char_offset": 52, "scope": "verse", "word_index": 8}, "marker": "e", "text": "Shaphir means pleasant ."}, {"anchor": {"anchor_index": 2, "char_offset": 75, "scope": "verse", "word_index": 12}, "marker": "f", "text": "Zaanan sounds like the Hebrew for come out ."}, {"anchor": {"anchor_index": 3, "char_offset": 104, "scope": "verse", "word_index": 17}, "marker": "g", "text": "Beth-ezel means adjoining house ."}], "12": [{"anchor": {"anchor_index": 1, "char_offset": 26, "scope": "verse", "word_index": 5}, "marker": "h", "text": "Maroth sounds like the Hebrew for bitter ."}], "13": [{"anchor": {"anchor_index": 1, "char_offset": 50, "scope": "verse", "word_index": 8}, "marker": "i", "text": "Lachish sounds like the Hebrew term for team of horses ."}], "14": [{"anchor": {"anchor_index": 1, "char_offset": 30, "scope": "verse", "word_index": 4}, "marker": "j", "text": "Or give dowry"}, {"anchor": {"anchor_index": 2, "char_offset": 49, "scope": "verse", "word_index": 6}, "marker": "k", "text": "Moresheth sounds like the Hebrew for gift or dowry ."}, {"anchor": {"anchor_index": 3, "char_offset": 70, "scope": "verse", "word_index": 10}, "marker": "l", "text": "Achzib means deception ."}], "15": [{"anchor": {"anchor_index": 1, "char_offset": 66, "scope": "verse", "word_index": 12}, "marker": "m", "text": "Mareshah sounds like the Hebrew for conqueror ."}], "8": [{"anchor": {"anchor_index": 1, "char_offset": 97, "scope": "verse", "word_index": 20}, "marker": "a", "text": "Or a serpent or a dragon"}, {"anchor": {"anchor_index": 2, "char_offset": 124, "scope": "v