verse", "word_index": 36}, "marker": "a", "text": "Or for the eye of the LORD is on all men and all the tribes of Israel"}], "10": [{"anchor": {"anchor_index": 1, "char_offset": 43, "scope": "verse", "word_index": 9}, "marker": "f", "text": "That is, the northern kingdom of Israel"}, {"anchor": {"anchor_index": 2, "char_offset": 217, "scope": "verse", "word_index": 42}, "marker": "g", "text": "Hebrew the River"}], "13": [{"anchor": {"anchor_index": 1, "char_offset": 116, "scope": "verse", "word_index": 25}, "marker": "h", "text": "Hebrew the sons of Javan"}], "4": [{"anchor": {"anchor_index": 1, "char_offset": 70, "scope": "verse", "word_index": 13}, "marker": "b", "text": "Or strike down her power on the sea"}], "7": [{"anchor": {"anchor_index": 1, "char_offset": 166, "scope": "verse", "word_index": 31}, "marker": "c", "text": "Or like a leader"}], "9": [{"anchor": {"anchor_index": 1, "char_offset": 134, "scope": "verse", "word_index": 22}, "marker": "d", "text": "Or righteous and endowed with salvation"}, {"anchor": {"anchor_index": 2, "char_offset": 198, "scope": "verse", "word_index": 36}, "marker": "e", "text": "Cited in Matthew 21:5 and John 12:15"}]}}, "translation": {"code": "BSB", "id": "bsb", "name": "Berean Study Bible"}}