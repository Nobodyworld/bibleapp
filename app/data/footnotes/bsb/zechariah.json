{"book": {"id": "zechariah", "name": "Zechariah", "osis": "Zech"}, "chapters": {"1": {"15": [{"anchor": {"anchor_index": 1, "char_offset": 121, "scope": "verse", "word_index": 25}, "marker": "b", "text": "Or they have overdone the punishment"}], "7": [{"anchor": {"anchor_index": 1, "char_offset": 68, "scope": "verse", "word_index": 12}, "marker": "a", "text": "Shebat is the eleventh month of the Hebrew lunar calendar, usually occurring within the months of January and February."}]}, "10": {"3": [{"anchor": {"anchor_index": 1, "char_offset": 69, "scope": "verse", "word_index": 12}, "marker": "a", "text": "Or these male goats"}]}, "11": {"10": [{"anchor": {"anchor_index": 1, "char_offset": 52, "scope": "verse", "word_index": 12}, "marker": "b", "text": "Or broke it ; similarly in verse 14"}], "2": [{"anchor": {"anchor_index": 1, "char_offset": 16, "scope": "verse", "word_index": 3}, "marker": "a", "text": "Or pine or juniper or fir"}]}, "12": {"10": [{"anchor": {"anchor_index": 1, "char_offset": 82, "scope": "verse", "word_index": 18}, "marker": "b", "text": "Or the Spirit"}, {"anchor": {"anchor_index": 2, "char_offset": 129, "scope": "verse", "word_index": 28}, "marker": "c", "text": "Or to Me"}, {"anchor": {"anchor_index": 3, "char_offset": 156, "scope": "verse", "word_index": 33}, "marker": "d", "text": "Cited in John 19:37"}], "8": [{"anchor": {"anchor_index": 1, "char_offset": 164, "scope": "verse", "word_index": 33}, "marker": "a", "text": "Or Angel"}]}, "13": {"2": [{"anchor": {"anchor_index": 1, "char_offset": 193, "scope": "verse", "word_index": 38}, "marker": "a", "text": "Or the unclean spirit"}], "5": [{"anchor": {"anchor_index": 1, "char_offset": 96, "scope": "verse", "word_index": 22}, "marker": "b", "text": "Or I am a farmer, for the land has been my livelihood since my youth."}], "6": [{"anchor": {"anchor_index": 1, "char_offset": 57, "scope": "verse", "word_index": 11}, "marker": "c", "text": "Literally between your hands"}], "7": [{"anchor": {"anchor_index": 1, "char_offset": 155, "scope": "verse", "word_index": 27}, "marker": "d", "text": "Cited in Matthew 26:31 and Mark 14:27"}]}, "14": {"16": [{"anchor": {"anchor_index": 1, "char_offset": 177, "scope": "verse", "word_index": 32}, "marker": "d", "text": "That is, Sukkot, the autumn feast of pilgrimage to Jerusalem; also translated as the Feast of Booths or the Feast of Shelters and originally called the Feast of Ingathering (see Exodus 23:16 and Exodus 34:22)."}], "20": [{"anchor": {"anchor_index": 1, "char_offset": 29, "scope": "verse", "word_index": 7}, "marker": "e", "text": "That is, the LORD"}], "21": [{"anchor": {"anchor_index": 1, "char_offset": 196, "scope": "verse", "word_index": 40}, "marker": "f", "text": "Or merchant"}], "5": [{"anchor": {"anchor_index": 1, "char_offset": 211, "scope": "verse", "word_index": 44}, "marker": "a", "text": "LXX; Hebrew with You"}], "8": [{"anchor": {"anchor_index": 1, "char_offset": 92, "scope": "verse", "word_index": 18}, "marker": "b", "text": "That is, the Dead Sea"}, {"anchor": {"anchor_index": 2, "char_offset": 135, "scope": "verse", "word_index": 26}, "marker": "c", "text": "That is, the Mediterranean Sea, also called the Great Sea"}]}, "2": {"8": [{"anchor": {"anchor_index": 1, "char_offset": 69, "scope": "verse", "word_index": 15}, "marker": "a", "text": "Or After the Glorious One has sent Me or After He has honored Me and sent Me"}, {"anchor": {"anchor_index": 2, "char_offset": 155, "scope": "verse", "word_index": 28}, "marker": "b", "text": "Or the pupil"}]}, "3": {"1": [{"anchor": {"anchor_index": 1, "char_offset": 73, "scope": "verse", "word_index": 13}, "marker": "a", "text": "Or Angel ; also in verses 3, 4, 5, and 6; corresponding pronouns may also be capitalized."}, {"anchor": {"anchor_index": 2, "char_offset": 97, "scope": "verse", "word_index": 18}, "marker": "b", "text": "That is, the Accuser or the Adversary ; also in verse 2"}], "2": [{"anchor": {"anchor_index": 1, "char_offset": 142, "scope": "ver